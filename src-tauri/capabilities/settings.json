{
  "identifier": "settings",
  "description": "Permissions for the settings window",
  "windows": ["settings"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-get-all-windows",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-load"
  ]
}
